<Page x:Class="EReceiptApp.Views.Pages.ReceiptPreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Receipt Preview"
      Background="{DynamicResource AppBackground}">

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid Margin="30">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="24"/>
				<ColumnDefinition Width="240"/>
			</Grid.ColumnDefinitions>

			<!-- ===== LEFT: Receipt Card ===== -->
			<Border Grid.Column="0"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="1" CornerRadius="12"
        Padding="40,36">
				<StackPanel x:Name="ReceiptContent" MaxWidth="480">

                    <!-- Logo (shown if uploaded) -->
                    <Image x:Name="ImgReceiptLogo"
					   Height="70" Width="70"
					   Stretch="Uniform"
					   HorizontalAlignment="Center"
					   Margin="0,0,0,12"
					   Visibility="Collapsed"/>


                    <!-- Header -->
					<TextBlock x:Name="TxtOrgName"
							   FontSize="18" FontWeight="Bold"
							   Foreground="{DynamicResource AppText}"
							   HorizontalAlignment="Center"
							   TextWrapping="Wrap" TextAlignment="Center"
							   Margin="0,0,0,4"/>

					<TextBlock x:Name="TxtClubName"
							   FontSize="13"
							   Foreground="{DynamicResource AppTextMuted}"
							   HorizontalAlignment="Center"
							   TextAlignment="Center"
							   Margin="0,0,0,0"/>

					<!-- Type Badge -->
					<Border x:Name="TypeBadge" CornerRadius="20"
							Padding="14,5" HorizontalAlignment="Center"
							Margin="0,12,0,20">
						<TextBlock x:Name="TxtTypeBadge"
								   FontSize="11" FontWeight="SemiBold"
								   HorizontalAlignment="Center"/>
					</Border>

					<!-- Receipt Info rows -->
					<Grid Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Receipt No."
								   FontSize="12"
								   Foreground="{DynamicResource AppTextMuted}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtReceiptNumber"
								   FontSize="12" FontWeight="SemiBold"
								   Foreground="{DynamicResource AppText}"
								   HorizontalAlignment="Right"
								   TextAlignment="Right"
								   TextWrapping="Wrap"/>
					</Grid>

					<Grid Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Date"
								   FontSize="12"
								   Foreground="{DynamicResource AppTextMuted}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtDate"
								   FontSize="12" FontWeight="SemiBold"
								   Foreground="{DynamicResource AppText}"
								   HorizontalAlignment="Right"
								   TextAlignment="Right"/>
					</Grid>

					<Grid Margin="0,0,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Cashier"
								   FontSize="12"
								   Foreground="{DynamicResource AppTextMuted}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtCashier"
								   FontSize="12" FontWeight="SemiBold"
								   Foreground="{DynamicResource AppText}"
								   HorizontalAlignment="Right"
								   TextAlignment="Right"/>
					</Grid>

					<!-- Dashed Divider -->
					<TextBlock Text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
							   FontSize="11" Foreground="{DynamicResource AppBorder}"
							   HorizontalAlignment="Stretch" TextAlignment="Center"
							   TextWrapping="NoWrap" Margin="0,16" Opacity="0.8"/>

					<!-- Recipient Section -->
					<TextBlock Text="RECIPIENT"
							   FontSize="10" FontWeight="Bold"
							   Foreground="{DynamicResource AppTextMuted}"
							   HorizontalAlignment="Left"
							   Margin="0,0,0,10"/>

					<Grid Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Name"
								   FontSize="12"
								   Foreground="{DynamicResource AppTextMuted}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtIssuedTo"
								   FontSize="12" FontWeight="SemiBold"
								   Foreground="{DynamicResource AppText}"
								   HorizontalAlignment="Right"
								   TextAlignment="Right"
								   TextWrapping="Wrap"/>
					</Grid>

					<!-- ID Number row -->
					<Grid x:Name="IdNumberRow" Margin="0,0,0,8"
						  Visibility="Collapsed">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="ID Number"
								   FontSize="12"
								   Foreground="{DynamicResource AppTextMuted}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtIdNumber"
								   FontSize="12" FontWeight="SemiBold"
								   Foreground="{DynamicResource AppText}"
								   HorizontalAlignment="Right"
								   TextAlignment="Right"/>
					</Grid>

					<!-- Membership Type row -->
					<Grid x:Name="MembershipRow" Margin="0,0,0,8"
						  Visibility="Collapsed">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Membership Type"
								   FontSize="12"
								   Foreground="{DynamicResource AppTextMuted}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtMembershipType"
								   FontSize="12" FontWeight="SemiBold"
								   Foreground="{DynamicResource AppText}"
								   HorizontalAlignment="Right"
								   TextAlignment="Right"
								   TextWrapping="Wrap"/>
					</Grid>

					<!-- Academic Year row -->
					<Grid x:Name="AcadYearRow" Margin="0,0,0,8"
						  Visibility="Collapsed">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="School Year"
								   FontSize="12"
								   Foreground="{DynamicResource AppTextMuted}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtAcadYear"
								   FontSize="12" FontWeight="SemiBold"
								   Foreground="{DynamicResource AppText}"
								   HorizontalAlignment="Right"
								   TextAlignment="Right"
								   TextWrapping="Wrap"/>
					</Grid>

					<!-- Dashed Divider -->
					<TextBlock Text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
							   FontSize="11" Foreground="{DynamicResource AppBorder}"
							   HorizontalAlignment="Stretch" TextAlignment="Center"
							   TextWrapping="NoWrap" Margin="0,16" Opacity="0.8"/>

					<!-- Items Section -->
					<TextBlock Text="ITEMS"
							   FontSize="10" FontWeight="Bold"
							   Foreground="{DynamicResource AppTextMuted}"
							   HorizontalAlignment="Left"
							   Margin="0,0,0,10"/>

					<!-- Items column headers -->
					<Grid Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="36"/>
							<ColumnDefinition Width="72"/>
							<ColumnDefinition Width="72"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Description"
								   FontSize="10" FontWeight="Bold"
								   Foreground="{DynamicResource AppTextMuted}"/>
						<TextBlock Grid.Column="1" Text="Qty"
								   FontSize="10" FontWeight="Bold"
								   Foreground="{DynamicResource AppTextMuted}"
								   TextAlignment="Center"/>
						<TextBlock Grid.Column="2" Text="Price"
								   FontSize="10" FontWeight="Bold"
								   Foreground="{DynamicResource AppTextMuted}"
								   TextAlignment="Right"/>
						<TextBlock Grid.Column="3" Text="Total"
								   FontSize="10" FontWeight="Bold"
								   Foreground="{DynamicResource AppTextMuted}"
								   TextAlignment="Right"/>
					</Grid>

					<!-- Items list populated in code -->
					<StackPanel x:Name="ItemsPanel" Margin="0,0,0,8"/>

					<!-- Solid line before total -->
					<Rectangle Height="1"
							   Fill="{DynamicResource AppBorder}"
							   Margin="0,8,0,12"
							   HorizontalAlignment="Stretch"/>

					<!-- Total row -->
					<Grid Margin="0,0,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="TOTAL"
								   FontSize="15" FontWeight="Bold"
								   Foreground="{DynamicResource AppText}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="1" x:Name="TxtTotal"
								   FontSize="15" FontWeight="Bold"
								   Foreground="{DynamicResource AppAccent}"
								   HorizontalAlignment="Right"/>
					</Grid>

					<!-- Notes -->
					<TextBlock x:Name="TxtNotes"
							   FontSize="11" FontStyle="Italic"
							   Foreground="{DynamicResource AppTextMuted}"
							   TextWrapping="Wrap"
							   Margin="0,12,0,0"
							   Visibility="Collapsed"/>

					<!-- Dashed Divider -->
					<TextBlock Text="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
							   FontSize="11" Foreground="{DynamicResource AppBorder}"
							   HorizontalAlignment="Stretch" TextAlignment="Center"
							   TextWrapping="NoWrap" Margin="0,16" Opacity="0.8"/>

					<!-- Footer -->
					<TextBlock Text="This is an official digital receipt."
							   FontSize="10"
							   Foreground="{DynamicResource AppTextMuted}"
							   HorizontalAlignment="Center"
							   TextAlignment="Center"/>
					<TextBlock Text="E-Receipt System v1.0"
							   FontSize="10"
							   Foreground="{DynamicResource AppTextMuted}"
							   HorizontalAlignment="Center"
							   TextAlignment="Center"
							   Margin="0,2,0,0"/>

				</StackPanel>
			</Border>

			<!-- ===== RIGHT: QR + Actions ===== -->
			<StackPanel Grid.Column="2">

				<!-- QR Code Card -->
				<Border Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="12"
                        Padding="20" Margin="0,0,0,12">
					<StackPanel>
						<TextBlock Text="QR Code" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>

						<!-- QR Image -->
						<Image x:Name="QrCodeImage"
                               Width="160" Height="160"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

						<TextBlock Text="Scan with your phone camera to save receipt details."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   TextAlignment="Center"/>
					</StackPanel>
				</Border>

				<!-- Action Buttons -->
				<Button Content="🖨️  Print Receipt"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Click="Print_Click"/>

				<Button Content="🖼️  Save as Image"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Click="SaveImage_Click"/>

				<Button Content="📄  Export as PDF"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Click="SavePdf_Click"/>

				<Button Content="📧  Send via Email"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Click="SendEmail_Click"/>

				<Button Content="← Back"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Stretch"
                        Click="Back_Click"/>

			</StackPanel>
		</Grid>
	</ScrollViewer>
</Page>