<Page x:Class="EReceiptApp.Views.Pages.ReceiptBuilderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Receipt Builder"
      Background="{DynamicResource AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT COLUMN ===== -->
            <StackPanel Grid.Column="0">

                <!-- Page header -->
                <TextBlock x:Name="PageTitle"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource AppText}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="PageSubtitle"
                           FontSize="13"
                           Foreground="{DynamicResource AppTextMuted}"
                           Margin="0,0,0,24"
                           TextWrapping="Wrap"/>

                <!-- ── Receipt Information ── -->
                <TextBlock Text="RECEIPT INFORMATION"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource AppTextMuted}"
                           Margin="0,0,0,8"/>
                <Separator Margin="0,0,0,12"/>

                <TextBlock Text="Receipt Number"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtReceiptNumber"
                         Style="{StaticResource InputBox}"
                         IsReadOnly="True"
                         Background="{DynamicResource AppSurfaceAlt}"/>

                <TextBlock Text="Date Issued"
                           Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="DpDateIssued"
                            FontSize="13" Padding="8"
                            BorderBrush="{DynamicResource AppBorder}"
                            Margin="0,0,0,4"/>

                <TextBlock Text="Cashier / Issued By ✱"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtCashier"
                         Style="{StaticResource InputBox}"
                         MaxLength="100"/>

                <TextBlock Text="Organization / Store (optional)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtOrganization"
                         Style="{StaticResource InputBox}"
                         MaxLength="150"/>

                <!-- ── Recipient Information ── -->
                <TextBlock Text="RECIPIENT INFORMATION"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource AppTextMuted}"
                           Margin="0,20,0,8"/>
                <Separator Margin="0,0,0,12"/>

                <TextBlock Text="Issued To ✱"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtIssuedTo"
                         Style="{StaticResource InputBox}"
                         MaxLength="100"/>

                <TextBlock Text="ID Number (optional)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtIdNumber"
                         Style="{StaticResource InputBox}"
                         MaxLength="30"/>

                <TextBlock Text="Notes / Remarks (optional)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtNotes"
                         Style="{StaticResource InputBox}"
                         Height="70" TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="300"/>

                <TextBlock Text="✱ Required fields"
                           FontSize="11"
                           Foreground="{DynamicResource AppTextMuted}"
                           Margin="0,10,0,0"/>

            </StackPanel>

            <!-- ===== RIGHT COLUMN ===== -->
            <StackPanel Grid.Column="2">

                <!-- ── Items / Fees ── -->
                <TextBlock Text="ITEMS / FEES"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource AppTextMuted}"
                           Margin="0,36,0,8"/>
                <Separator Margin="0,0,0,12"/>

                <!-- Column headers -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Description"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="Qty"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="2" Text="Unit Price"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="3" Text="Total"
                               Style="{StaticResource FieldLabel}"/>
                </Grid>

                <!-- Dynamic item rows -->
                <StackPanel x:Name="ItemsPanel"/>

                <!-- Add item buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="+ Add Item"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6" FontSize="12"
                            Margin="0,0,8,0"
                            Click="AddItem_Click"/>
                    <Button Content="📋 Pick from List"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6" FontSize="12"
                            Click="PickPreset_Click"/>
                </StackPanel>

                <!-- Totals -->
                <Border Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Margin="0,16,0,0" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Subtotal:"
                                       FontSize="13"
                                       Foreground="{DynamicResource AppTextMuted}"/>
                            <TextBlock x:Name="TxtSubtotal"
                                       Text="₱0.00"
                                       FontSize="13"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource AppText}"/>
                        </Grid>
                        <Separator Margin="0,6"/>
                        <Grid>
                            <TextBlock Text="TOTAL"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource AppText}"/>
                            <TextBlock x:Name="TxtTotal"
                                       Text="₱0.00"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource AppAccent}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Right">
                    <Button Content="Clear Form"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,8" FontSize="12"
                            Margin="0,0,10,0"
                            Click="ClearForm_Click"/>
                    <Button Content="Preview Receipt →"
                            Style="{StaticResource PrimaryButton}"
                            Padding="14,8" FontSize="12"
                            Click="PreviewReceipt_Click"/>
                </StackPanel>

                <!-- Validation -->
                <Border x:Name="ValidationPanel"
                        Background="{DynamicResource AppDangerLight}"
                        BorderBrush="{DynamicResource AppDanger}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="12" Margin="0,10,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtValidation"
                               Foreground="{DynamicResource AppDanger}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>