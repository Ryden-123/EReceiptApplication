<Page x:Class="EReceiptApp.Views.Pages.ManageItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Manage Items"
      Background="{DynamicResource AppBackground}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Manage Items"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource AppText}"/>
                <TextBlock Text="Add and manage preset items for the receipt builder dropdown."
                           FontSize="13"
                           Foreground="{DynamicResource AppTextMuted}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="+ Add New Item"
                    Style="{StaticResource PrimaryButton}"
                    Padding="16,10" FontSize="13"
                    VerticalAlignment="Center"
                    Click="AddItem_Click"/>
        </Grid>

        <!-- Search + filter toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="TxtSearch"
                     Padding="10,8" FontSize="13"
                     BorderBrush="{DynamicResource AppBorder}"
                     BorderThickness="1"
                     Background="{DynamicResource AppSurface}"
                     Foreground="{DynamicResource AppText}"
                     TextChanged="Search_Changed"/>

            <ComboBox Grid.Column="2"
                      x:Name="CmbCategory"
                      Padding="10,8" FontSize="13"
                      BorderBrush="{DynamicResource AppBorder}"
                      SelectionChanged="Category_Changed"/>
        </Grid>

        <!-- Stats bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <TextBlock Text="Total items: "
                               FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"/>
                    <TextBlock x:Name="TxtTotalCount"
                               Text="0" FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppAccent}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <TextBlock Text="Categories: "
                               FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"/>
                    <TextBlock x:Name="TxtCategoryCount"
                               Text="0" FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppAccent}"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <TextBlock Text="Showing: "
                               FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"/>
                    <TextBlock x:Name="TxtShowingCount"
                               Text="0" FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppAccent}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items table -->
        <Border Grid.Row="3"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1" CornerRadius="10"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Name"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="16,10,0,10"/>
                        <TextBlock Grid.Column="1"
                                   Text="Category"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                        <TextBlock Grid.Column="2"
                                   Text="Price"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                        <TextBlock Grid.Column="3"
                                   Text="Description"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                        <TextBlock Grid.Column="4"
                                   Text="Actions"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                    </Grid>
                </Border>

                <!-- Items list -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ItemsPanel"/>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyPanel"
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,48"
                            Visibility="Collapsed">
                    <TextBlock Text="📦" FontSize="40"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="No items found"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Click + Add New Item to get started."
                               FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Page>