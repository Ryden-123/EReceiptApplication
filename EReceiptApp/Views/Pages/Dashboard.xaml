<Page x:Class="EReceiptApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard"
      Background="{DynamicResource AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TxtGreeting"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource AppText}"/>
                    <TextBlock x:Name="TxtDate"
                               FontSize="13"
                               Foreground="{DynamicResource AppTextMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Export buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="📊  Export Excel"
                            Padding="14,8" FontSize="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource AppBorder}"
                            Background="{DynamicResource AppSurface}"
                            Foreground="{DynamicResource AppText}"
                            Cursor="Hand" Margin="0,0,8,0"
                            Click="ExportExcel_Click"/>
                    <Button Content="📄  Export CSV"
                            Padding="14,8" FontSize="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource AppBorder}"
                            Background="{DynamicResource AppSurface}"
                            Foreground="{DynamicResource AppText}"
                            Cursor="Hand" Margin="0,0,8,0"
                            Click="ExportCsv_Click"/>
                    <Button Content="✅  Verify Receipt"
                            Padding="14,8" FontSize="12"
                            BorderThickness="0"
                            Background="{DynamicResource AppAccent}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="VerifyReceipt_Click"/>
                </StackPanel>
            </Grid>

            <!-- Stat cards row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- This month total -->
                <Border Grid.Column="0"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="This Month"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock x:Name="StatMonthTotal"
                                   Text="₱0.00"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AppAccent}"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="StatMonthCount"
                                   Text="0 receipts"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Standard -->
                <Border Grid.Column="2"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Standard Receipts"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock x:Name="StatStandard"
                                   Text="0"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="StatStandardAmt"
                                   Text="₱0.00 total"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Membership -->
                <Border Grid.Column="4"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Membership Receipts"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock x:Name="StatMembership"
                                   Text="0"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#512DA8"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="StatMembershipAmt"
                                   Text="₱0.00 total"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- All time total -->
                <Border Grid.Column="6"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="All Time Collected"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock x:Name="StatAllTime"
                                   Text="₱0.00"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AppAccent}"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="StatAllTimeCount"
                                   Text="0 total receipts"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Chart + Top recipients row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Collections chart -->
                <Border Grid.Column="0"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Collections — Last 30 Days"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppText}"
                                   Margin="0,0,0,16"/>
                        <!-- Chart canvas -->
                        <Canvas x:Name="ChartCanvas"
                                Height="180"
                                Background="Transparent"/>
                        <TextBlock x:Name="TxtNoChartData"
                                   Text="No data yet for the last 30 days."
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Top recipients -->
                <Border Grid.Column="2"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Top Recipients"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppText}"
                                   Margin="0,0,0,14"/>
                        <StackPanel x:Name="TopRecipientsPanel"/>
                        <TextBlock x:Name="TxtNoRecipients"
                                   Text="No receipts yet."
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent receipts -->
            <Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Recent Receipts"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,14"/>
                    <StackPanel x:Name="RecentReceiptsPanel"/>
                    <TextBlock x:Name="TxtNoRecent"
                               Text="No receipts yet. Create your first receipt!"
                               FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>