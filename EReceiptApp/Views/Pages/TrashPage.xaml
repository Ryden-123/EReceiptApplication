<Page x:Class="EReceiptApp.Views.Pages.TrashPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Trash"
      Background="{DynamicResource AppBackground}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="🗑  Trash"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource AppText}"/>
                <TextBlock Text="Deleted receipts — restore or permanently delete."
                           FontSize="13"
                           Foreground="{DynamicResource AppTextMuted}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="← Back to Receipts"
                        Padding="14,8" FontSize="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AppBorder}"
                        Background="{DynamicResource AppSurface}"
                        Foreground="{DynamicResource AppText}"
                        Cursor="Hand" Margin="0,0,10,0"
                        Click="Back_Click"/>
                <Button Content="🗑  Empty Trash"
                        Padding="14,8" FontSize="12"
                        BorderThickness="1"
                        BorderBrush="#FFCDD2"
                        Background="#FFF0F0"
                        Foreground="#C62828"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="EmptyTrash_Click"/>
            </StackPanel>
        </Grid>

        <!-- Empty state -->
        <Border Grid.Row="1"
                x:Name="EmptyPanel"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1" CornerRadius="10"
                Padding="40" Margin="0,0,0,0"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🗑" FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Trash is empty"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppText}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Deleted receipts will appear here."
                           FontSize="13"
                           Foreground="{DynamicResource AppTextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Trash table -->
        <Border Grid.Row="2"
                x:Name="TablePanel"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1" CornerRadius="10"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Receipt No."
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="16,10,0,10"/>
                        <TextBlock Grid.Column="1" Text="Type"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                        <TextBlock Grid.Column="2" Text="Issued To"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                        <TextBlock Grid.Column="3" Text="Deleted"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                        <TextBlock Grid.Column="4" Text="Total"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                        <TextBlock Grid.Column="5" Text="Actions"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10"/>
                    </Grid>
                </Border>

                <!-- Rows -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TrashPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</Page>