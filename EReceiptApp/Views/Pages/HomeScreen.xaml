<Page x:Class="EReceiptApp.Views.Pages.HomeScreen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home"
      Background="{DynamicResource AppBackground}">

	<Page.Resources>
		<Style x:Key="HomeCard" TargetType="Border">
			<Setter Property="Background"      Value="{DynamicResource AppSurface}"/>
			<Setter Property="BorderBrush"     Value="{DynamicResource AppBorder}"/>
			<Setter Property="BorderThickness" Value="1.5"/>
			<Setter Property="CornerRadius"    Value="18"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Width"           Value="190"/>
			<Setter Property="Padding"         Value="24,28"/>
		</Style>
	</Page.Resources>

	<Grid>
		<StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

			<!-- Logo -->
			<Border Width="88" Height="88"
                    CornerRadius="22"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">
				<Border.Background>
					<LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
						<GradientStop Color="#7C6FCD" Offset="0"/>
						<GradientStop Color="#9B6CD4" Offset="1"/>
					</LinearGradientBrush>
				</Border.Background>
				<TextBlock Text="🧾" FontSize="40"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
			</Border>

			<!-- Title -->
			<TextBlock Text="E-Receipt System"
                       FontSize="32" FontWeight="Bold"
                       Foreground="{DynamicResource AppText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

			<TextBlock Text="Digital receipts for your organization"
                       FontSize="14"
                       Foreground="{DynamicResource AppTextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,48"/>

			<!-- Cards row -->
			<StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

				<!-- Start -->
				<Border x:Name="StartCard"
                        Style="{StaticResource HomeCard}"
                        Margin="10,0">
					<StackPanel>
						<Border Width="54" Height="54"
                                CornerRadius="14"
                                Background="{DynamicResource AppAccentLight}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
							<TextBlock Text="🧾" FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="Start"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource AppText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
						<TextBlock Text="Create and manage receipts"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
					</StackPanel>
				</Border>

				<!-- Settings -->
				<Border x:Name="SettingsCard"
                        Style="{StaticResource HomeCard}"
                        Margin="10,0">
					<StackPanel>
						<Border Width="54" Height="54"
                                CornerRadius="14"
                                Background="#E8F5EE"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
							<TextBlock Text="⚙️" FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="Settings"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource AppText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
						<TextBlock Text="Themes and preferences"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
					</StackPanel>
				</Border>

				<!-- About -->
				<Border x:Name="AboutCard"
                        Style="{StaticResource HomeCard}"
                        Margin="10,0">
					<StackPanel>
						<Border Width="54" Height="54"
                                CornerRadius="14"
                                Background="#FFF8E6"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
							<TextBlock Text="ℹ️" FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="About"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource AppText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
						<TextBlock Text="What this app is about"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
					</StackPanel>
				</Border>

			</StackPanel>

			<!-- Version -->
			<TextBlock Text="E-Receipt System v1.0"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,48,0,0"/>

		</StackPanel>
	</Grid>
</Page>