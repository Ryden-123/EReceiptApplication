<Page x:Class="EReceiptApp.Views.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="About"
      Background="{DynamicResource AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40" MaxWidth="560">

            <!-- Page title -->
            <TextBlock Text="About"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource AppText}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="E-bidensya v1.0"
                       FontSize="13"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,32"/>

            <!-- What is this app -->
            <Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="14"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="What is this app?"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,10">
                        E-Bidensya (from the Filipino word "ebidensya" meaning
                        evidence or proof) is a digital receipt generator
                        designed for stores, organizations, and clubs. It allows
                        cashiers and officers to issue official digital receipts
                        without the need for paper.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource AppText}">
                        Transactions become faster, more organized,
                        and environmentally friendly — and recipients
                        can keep their receipt on their phone by
                        scanning the QR code.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Key Features -->
            <Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="14"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Key Features"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,14"/>

                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🧾  "/>
                        <Run Text="Create general receipts for any type of transaction"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="📱  "/>
                        <Run Text="QR Code generation so recipients can scan and save"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🖨️  "/>
                        <Run Text="Print receipts directly from the app"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🖼️  "/>
                        <Run Text="Export receipts as PNG images"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="📄  "/>
                        <Run Text="Export receipts as PDF documents"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="📧  "/>
                        <Run Text="Send receipts via email with attachments"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="📋  "/>
                        <Run Text="Full receipt history with search and filter"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="✅  "/>
                        <Run Text="QR code verification to confirm authenticity"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="📊  "/>
                        <Run Text="Dashboard with collection stats and charts"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="💾  "/>
                        <Run Text="Export receipts to Excel or CSV spreadsheets"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,0"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🌙  "/>
                        <Run Text="Light and dark mode with custom accent colors"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Who is this for -->
            <Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="14"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Who is this for?"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,14"/>

                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🏪  "/>
                        <Run Text="Stores and small businesses"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🏫  "/>
                        <Run Text="Student organizations and clubs"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🎪  "/>
                        <Run Text="Events and registrations"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource AppText}">
                        <Run Text="🏢  "/>
                        <Run Text="Any organization that issues receipts regularly"/>
                    </TextBlock>

                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               FontStyle="Italic"
                               Foreground="{DynamicResource AppTextMuted}"
                               Margin="0,10,0,0">
                        Recipients scan the QR code on their phone
                        as proof of payment — no paper needed.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>