<Page x:Class="EReceiptApp.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="{DynamicResource AppBackground}">

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Margin="40" MaxWidth="560">

			<!-- Title -->
			<TextBlock Text="Settings" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource AppText}"
                       Margin="0,0,0,4"/>
			<TextBlock Text="Customize the look and feel of the app."
                       FontSize="13"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,32"/>

            <!-- Logo Section -->
            <TextBlock Text="ORGANIZATION LOGO"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="14"
                    Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Receipt Logo"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppText}"
                   Margin="0,0,0,6"/>
                    <TextBlock Text="This logo appears at the top of all receipts and exported files."
                   FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource AppTextMuted}"
                   Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

                        <!-- Logo preview -->
                        <Border Width="80" Height="80"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1.5"
                    Margin="0,0,16,0">
                            <Grid>
                                <TextBlock x:Name="TxtLogoPlaceholder"
                               Text="🏢" FontSize="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                                <Image x:Name="ImgLogoPreview"
                           Stretch="UniformToFill"
                           Visibility="Collapsed">
                                    <Image.Clip>
                                        <RectangleGeometry RadiusX="10" RadiusY="10"
                                               Rect="0,0,80,80"/>
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>

                        <!-- Upload buttons -->
                        <StackPanel VerticalAlignment="Center">
                            <Button Content="📁  Upload Logo"
                        Style="{StaticResource PrimaryButton}"
                        Padding="14,8" FontSize="12"
                        Margin="0,0,0,8"
                        Click="UploadLogo_Click"/>
                            <Button x:Name="BtnRemoveLogo"
                        Content="Remove Logo"
                        Style="{StaticResource SecondaryButton}"
                        Padding="14,8" FontSize="12"
                        Visibility="Collapsed"
                        Click="RemoveLogo_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>


            <!-- Theme Section -->
			<TextBlock Text="THEME" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,10"/>
			<Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,20">
				<StackPanel>
					<TextBlock Text="Color Mode" FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,14"/>
					<StackPanel Orientation="Horizontal">
						<RadioButton x:Name="RadioLight"
                                     Content="☀️  Light Mode"
                                     GroupName="Theme" IsChecked="True"
                                     FontSize="13"
                                     Foreground="{DynamicResource AppText}"
                                     Margin="0,0,24,0"/>
						<RadioButton x:Name="RadioDark"
                                     Content="🌙  Dark Mode"
                                     GroupName="Theme"
                                     FontSize="13"
                                     Foreground="{DynamicResource AppText}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Accent Color Section -->
			<TextBlock Text="ACCENT COLOR" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,10"/>
			<Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,20">
				<StackPanel>
					<TextBlock Text="Choose an accent color"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,14"/>
					<StackPanel Orientation="Horizontal">
						<Border x:Name="AccentPurple" Width="40" Height="40"
                                CornerRadius="20" Background="#5C4ABB"
                                Cursor="Hand" Margin="0,0,10,0"
                                MouseLeftButtonUp="AccentPurple_Click">
							<TextBlock x:Name="CheckPurple" Text="✓"
                                       FontSize="16" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<Border x:Name="AccentBlue" Width="40" Height="40"
                                CornerRadius="20" Background="#1976D2"
                                Cursor="Hand" Margin="0,0,10,0"
                                MouseLeftButtonUp="AccentBlue_Click">
							<TextBlock x:Name="CheckBlue" Text="✓"
                                       FontSize="16" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
						</Border>
						<Border x:Name="AccentGreen" Width="40" Height="40"
                                CornerRadius="20" Background="#2E7D32"
                                Cursor="Hand" Margin="0,0,10,0"
                                MouseLeftButtonUp="AccentGreen_Click">
							<TextBlock x:Name="CheckGreen" Text="✓"
                                       FontSize="16" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
						</Border>
						<Border x:Name="AccentRed" Width="40" Height="40"
                                CornerRadius="20" Background="#C62828"
                                Cursor="Hand" Margin="0,0,10,0"
                                MouseLeftButtonUp="AccentRed_Click">
							<TextBlock x:Name="CheckRed" Text="✓"
                                       FontSize="16" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
						</Border>
						<Border x:Name="AccentTeal" Width="40" Height="40"
                                CornerRadius="20" Background="#00695C"
                                Cursor="Hand" Margin="0,0,10,0"
                                MouseLeftButtonUp="AccentTeal_Click">
							<TextBlock x:Name="CheckTeal" Text="✓"
                                       FontSize="16" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
						</Border>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- EMAIL SETTINGS — must be inside the StackPanel -->
			<TextBlock Text="EMAIL SETTINGS" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,10"/>

			<Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="20" Margin="0,0,0,10">
				<StackPanel>
					<TextBlock Text="Gmail Configuration"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,6"/>
					<TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"
                               Margin="0,0,0,16">
						Enter your Gmail address and App Password below.
						Never use your real Gmail password here.
					</TextBlock>

					<TextBlock Text="Gmail Address" FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextMuted}"
                               Margin="0,0,0,4"/>
					<TextBox x:Name="TxtGmail"
                             Padding="8,6" FontSize="13"
                             BorderBrush="{DynamicResource AppBorder}"
                             Background="{DynamicResource AppInputBackground}"
                             Foreground="{DynamicResource AppText}"
                             MaxLength="200"
                             Margin="0,0,0,12"/>

					<TextBlock Text="App Password (16 characters)"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextMuted}"
                               Margin="0,0,0,4"/>
					<PasswordBox x:Name="TxtAppPassword"
                                 Padding="8,6" FontSize="13"
                                 BorderBrush="{DynamicResource AppBorder}"
                                 Background="{DynamicResource AppInputBackground}"
                                 MaxLength="32"
                                 Margin="0,0,0,16"/>

					<Button Content="Save Email Settings"
                            Padding="14,8" FontSize="13"
                            BorderThickness="0"
                            Background="{DynamicResource AppAccent}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            HorizontalAlignment="Left"
                            Click="SaveEmailSettings_Click"/>

					<TextBlock x:Name="TxtEmailSaved"
                               Text="✓ Email settings saved!"
                               FontSize="12" Foreground="#2E7D32"
                               Margin="0,10,0,0"
                               Visibility="Collapsed"/>
				</StackPanel>
			</Border>
            
            <!-- Database Backup -->
<TextBlock Text="DATABASE" FontSize="11" FontWeight="Bold"
           Foreground="{DynamicResource AppTextMuted}"
           Margin="0,20,0,10"/>

<Border Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="1" CornerRadius="10"
        Padding="20" Margin="0,0,0,20">
    <StackPanel>
        <TextBlock Text="Database Backup"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppText}"
                   Margin="0,0,0,6"/>
        <TextBlock TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource AppTextMuted}"
                   Margin="0,0,0,16">
            Export a copy of your receipts database to
            keep as a backup. This copies the receipts.db
            file to a location of your choice.
        </TextBlock>

        <StackPanel Orientation="Horizontal">
            <Button Content="💾  Backup Database"
                    Padding="14,8" FontSize="13"
                    BorderThickness="0"
                    Background="{DynamicResource AppAccent}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Margin="0,0,10,0"
                    Click="BackupDatabase_Click"/>

            <Button Content="📂  Restore Database"
                    Padding="14,8" FontSize="13"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AppBorder}"
                    Background="{DynamicResource AppSurface}"
                    Foreground="{DynamicResource AppText}"
                    Cursor="Hand"
                    Click="RestoreDatabase_Click"/>
        </StackPanel>

        <TextBlock x:Name="TxtBackupStatus"
                   FontSize="12" Foreground="#2E7D32"
                   Margin="0,10,0,0"
                   Visibility="Collapsed"/>
    </StackPanel>
</Border>

			<!-- App Password help -->
			<Border Background="{DynamicResource AppSurfaceAlt}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="16" Margin="0,0,0,20">
				<StackPanel>
					<TextBlock Text="How to get a Gmail App Password"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               Margin="0,0,0,8"/>
					<TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"
                               LineHeight="20">
						1. Go to myaccount.google.com&#10;
						2. Click Security and enable 2-Step Verification&#10;
						3. Search for App Passwords&#10;
						4. Choose Mail and Windows Computer&#10;
						5. Copy the 16-character password and paste it above
					</TextBlock>
				</StackPanel>
			</Border>
            
            

		</StackPanel>
        
        
	</ScrollViewer>
    
    
</Page>