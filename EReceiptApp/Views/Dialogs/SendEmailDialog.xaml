<Window x:Class="EReceiptApp.Views.Dialogs.SendEmailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Receipt via Email"
        Width="460" Height="340"
        MinWidth="400" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}">

	<ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="30">
		<StackPanel>

			<TextBlock Text="Send Receipt via Email"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource AppText}"
                       Margin="0,0,0,6"/>

			<TextBlock Text="The receipt will be attached as PNG and PDF."
                       FontSize="12"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,24"
                       TextWrapping="Wrap"/>

			<!-- Recipient name -->
			<TextBlock Text="Recipient Name"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,4"/>
			<TextBox x:Name="TxtName"
                     Padding="8,6" FontSize="13"
                     BorderBrush="{DynamicResource AppBorder}"
                     BorderThickness="1"
                     Background="{DynamicResource AppSurface}"
                     Foreground="{DynamicResource AppText}"
                     MaxLength="100"
                     Margin="0,0,0,16"/>

			<!-- Recipient email -->
			<TextBlock Text="Recipient Email Address"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,4"/>
			<TextBox x:Name="TxtEmail"
                     Padding="8,6" FontSize="13"
                     BorderBrush="{DynamicResource AppBorder}"
                     BorderThickness="1"
                     Background="{DynamicResource AppSurface}"
                     Foreground="{DynamicResource AppText}"
                     MaxLength="200"
                     Margin="0,0,0,6"/>

			<!-- Validation message -->
			<TextBlock x:Name="TxtError"
                       FontSize="11" Foreground="#E74C3C"
                       Margin="0,0,0,16"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

			<!-- Buttons -->
			<StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
				<Button Content="Cancel"
                        Padding="16,8" FontSize="13"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AppBorder}"
                        Background="{DynamicResource AppSurface}"
                        Foreground="{DynamicResource AppText}"
                        Cursor="Hand" Margin="0,0,10,0"
                        Click="Cancel_Click"/>
				<Button Content="Send Email"
                        Padding="16,8" FontSize="13"
                        BorderThickness="0"
                        Background="{DynamicResource AppAccent}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="Send_Click"/>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>
</Window>