<Window x:Class="EReceiptApp.Views.Dialogs.ItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item"
        Width="420" Height="380"
        MinWidth="380" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="28">
        <StackPanel>

            <TextBlock x:Name="TxtDialogTitle"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource AppText}"
                       Margin="0,0,0,20"/>

            <!-- Name -->
            <TextBlock Text="Item Name ✱"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="TxtName"
                     Style="{StaticResource InputBox}"
                     MaxLength="100"
                     Margin="0,0,0,14"/>

            <!-- Category -->
            <TextBlock Text="Category"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          x:Name="CmbCategory"
                          Padding="10,8" FontSize="13"
                          BorderBrush="{DynamicResource AppBorder}"
                          IsEditable="True"/>
                <TextBlock Grid.Column="2"
                           Text="or type a new one"
                           FontSize="11"
                           Foreground="{DynamicResource AppTextMuted}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Price -->
            <TextBlock Text="Default Price (₱) ✱"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="TxtPrice"
                     Style="{StaticResource InputBox}"
                     MaxLength="10"
                     Margin="0,0,0,14"/>

            <!-- Description -->
            <TextBlock Text="Description (optional)"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextMuted}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="TxtDescription"
                     Style="{StaticResource InputBox}"
                     Height="70" TextWrapping="Wrap"
                     AcceptsReturn="True"
                     MaxLength="200"
                     Margin="0,0,0,6"/>

            <!-- Error -->
            <TextBlock x:Name="TxtError"
                       FontSize="11" Foreground="#C65050"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Padding="14,8" FontSize="13"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button x:Name="BtnSave"
                        Content="Save Item"
                        Style="{StaticResource PrimaryButton}"
                        Padding="14,8" FontSize="13"
                        Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>