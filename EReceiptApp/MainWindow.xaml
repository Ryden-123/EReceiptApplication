<Window x:Class="EReceiptApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-Receipt System"
        Height="720" Width="1080"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        KeyDown="MainWindow_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0"
                x:Name="SidebarPanel"
                Background="{DynamicResource AppSidebar}"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo area -->
                <StackPanel Grid.Row="0" Margin="16,24,16,20">
                    <Border Width="44" Height="44"
                            CornerRadius="12"
                            Background="{DynamicResource AppAccent}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12">
                        <TextBlock Text="🧾" FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="E-Receipt"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="System"
                               FontSize="11"
                               Foreground="{DynamicResource AppSidebarText}"
                               Margin="0,1,0,0"/>
                </StackPanel>

                <!-- Nav buttons -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="8,0">

                        <Button Content="🏠  Home"
                                Style="{StaticResource SidebarButton}"
                                Click="Home_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Home (Ctrl+Home)"/>
                            </Button.ToolTip>
                        </Button>

                        <Button Content="📊  Dashboard"
                                Style="{StaticResource SidebarButton}"
                                Click="Dashboard_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Dashboard"/>
                            </Button.ToolTip>
                        </Button>

                        <Separator Background="#3D3460"
                                   Margin="8,6"/>

                        <TextBlock Text="RECEIPTS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#6B6490"
                                   Margin="16,6,0,4"/>

                        <Button Content="🧾  New Standard"
                                Style="{StaticResource SidebarButton}"
                                Click="NewStandardReceipt_Click">
                            <Button.ToolTip>
                                <ToolTip Content="New Standard Receipt (Ctrl+N)"/>
                            </Button.ToolTip>
                        </Button>

                        <Button Content="🪪  New Membership"
                                Style="{StaticResource SidebarButton}"
                                Click="NewMembershipReceipt_Click">
                            <Button.ToolTip>
                                <ToolTip Content="New Membership Receipt (Ctrl+M)"/>
                            </Button.ToolTip>
                        </Button>

                        <Separator Background="#3D3460"
                                   Margin="8,6"/>

                        <TextBlock Text="HISTORY"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#6B6490"
                                   Margin="16,6,0,4"/>

                        <Button Content="📋  View All Receipts"
                                Style="{StaticResource SidebarButton}"
                                Click="ViewReceipts_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Receipt History (Ctrl+H)"/>
                            </Button.ToolTip>
                        </Button>

                        <Button Content="🗑  Trash"
                                Style="{StaticResource SidebarButton}"
                                Click="Trash_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Deleted receipts"/>
                            </Button.ToolTip>
                        </Button>

                        <Separator Background="#3D3460"
                                   Margin="8,6"/>

                        <TextBlock Text="TOOLS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#6B6490"
                                   Margin="16,6,0,4"/>

                        <Button Content="✅  Verify Receipt"
                                Style="{StaticResource SidebarButton}"
                                Click="Verify_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Verify a receipt is authentic"/>
                            </Button.ToolTip>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom buttons -->
                <StackPanel Grid.Row="2" Margin="8,0,8,16">
                    <Separator Background="#3D3460" Margin="8,0,8,6"/>
                    <Button Content="⚙️  Settings"
                            Style="{StaticResource SidebarButton}"
                            Click="Settings_Click"/>
                    <Button Content="ℹ️  About"
                            Style="{StaticResource SidebarButton}"
                            Click="About_Click"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Main content frame ── -->
        <Frame Grid.Column="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               JournalOwnership="OwnsJournal"
               Background="{DynamicResource AppBackground}"/>

    </Grid>
</Window>